# 자동 줄바꿈 정규화 (저장소에는 LF로 저장)
* text=auto eol=lf

# Java 소스
*.java     text eol=lf
*.kt       text eol=lf
*.groovy   text eol=lf

# Gradle / 빌드
*.gradle   text eol=lf
*.gradle.kts text eol=lf
gradlew    text eol=lf
*.properties text eol=lf

# 문서 / 설정
*.md       text eol=lf
*.txt      text eol=lf
*.xml      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.bat      text eol=crlf
*.cmd      text eol=crlf

# 바이너리
*.jar      binary
*.war      binary
*.class    binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.zip      binary
